# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Casper Blockchain Configuration
# Option 1: Official Casper Network nodes (Recommended)
# Testnet: CASPER_RPC_URL=https://node.testnet.casper.network/rpc
# Mainnet: CASPER_RPC_URL=https://node.mainnet.casper.network/rpc

# Option 2: CSPR.cloud (Professional service, may require API key)
# Testnet: CASPER_RPC_URL=https://testnet.cspr.cloud/rpc?apiKey=YOUR_API_KEY
# Mainnet: CASPER_RPC_URL=https://cspr.cloud/rpc?apiKey=YOUR_API_KEY

# Option 3: Community nodes (may have rate limits)
# CASPER_RPC_URL=https://rpc.cspr.live
# CASPER_RPC_URL=https://node.asgard.validators.cspr.live/rpc

CASPER_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_ID=1

# Logging
LOG_LEVEL=info

# Alert Configuration (optional)
ALERT_CHECK_INTERVAL=60 # seconds

# Signing Key for Write Operations (required for transfer, mint, stake, etc.)
# Option 1: Hex format private key (without 0x prefix)
# CASPER_SIGNING_KEY_HEX=your_private_key_hex_here
# Option 2: PEM format private key
# CASPER_SIGNING_KEY_PEM=-----BEGIN PRIVATE KEY-----
# ...your_pem_key...
# -----END PRIVATE KEY-----
# Key algorithm: ed25519 (default) or secp256k1
# CASPER_KEY_ALGORITHM=ed25519
# Generate keys with: npx casper-client keygen -a ed25519
